---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "DryTech.hk — Hong Kong's Ceiling Dehumidifier Specialist",
  description =
    'Ultra-thin ceiling dehumidifiers for Hong Kong homes and businesses. Whole-space humidity control from 20 to 400 L/day. Smart app control, built-in drain pump.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const site = 'https://www.drytech.hk';
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const isHome = Astro.url.pathname === '/';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site}/#organization`,
  name: 'DryTech.hk',
  url: `${site}/`,
  logo: `${site}/images/drytech-logo.png`,
  email: 'info@drytech.hk',
  telephone: '+852 2121 0968',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+852 2121 0968',
    contactType: 'sales',
    areaServed: 'HK',
    availableLanguage: ['English', 'Cantonese'],
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site}/#localbusiness`,
  name: 'DryTech.hk — Ceiling Dehumidifier Specialist',
  url: `${site}/`,
  image: `${site}/og-image.jpg`,
  telephone: '+852 2121 0968',
  email: 'info@drytech.hk',
  priceRange: '$$',
  areaServed: 'HK',
  description:
    'Ultra-thin ceiling dehumidifiers for Hong Kong homes and businesses. Whole-space humidity control from 20 to 400 L/day.',
  parentOrganization: { '@type': 'Organization', name: 'DBA Electric', url: 'https://dba.hk' },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${site}${ogImage}`} />
    <meta property="og:site_name" content="DryTech.hk" />
    <meta property="og:locale" content="en_HK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}${ogImage}`} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />}
    <slot name="head" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      /* Lenis smooth scroll baseline */
      html.lenis, html.lenis body { height: auto; }
      .lenis.lenis-smooth { scroll-behavior: auto !important; }
      .lenis.lenis-stopped { overflow: hidden; }

      /* Hero word overflow clip — parent divs clip sliding-up reveal */
      .hero-word { display: block; }
    </style>
  </head>
  <body class="bg-white text-slate-900 antialiased overflow-x-hidden">
    <slot />
    <script>
      import '../scripts/animations';
    </script>
  </body>
</html>
